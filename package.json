{
  "name": "glim-node",
  "version": "0.0.16",
  "repository": {
    "type": "git",
    "url": "https://github.com/ErickCReis/glim-node.git"
  },
  "bin": {
    "gn": "dist/bin/index.js"
  },
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "dist",
    "dist/templates/**/*"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "default": "./dist/helpers/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    }
  },
  "scripts": {
    "build": "bunup",
    "check": "oxfmt && oxlint --fix && tsgo --noEmit",
    "dev": "bunup --watch",
    "test": "bun test && tsgo -p test/types/tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.9",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/client-sns": "^3.1016.0",
    "@clack/prompts": "^1.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "^7.0.0-dev.20260325.1",
    "bun-types": "^1.3.11",
    "bunup": "^0.16.31",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.3",
    "pg": "^8.20.0",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3",
    "@aws-sdk/client-sns": ">=3",
    "@types/pg": ">=8.11",
    "dotenv": ">=16",
    "drizzle-orm": ">=0.40",
    "ioredis": ">=5.5",
    "mysql2": ">=3.0",
    "pg": ">=8.13",
    "zod": ">=3.24"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/client-sns": {
      "optional": true
    },
    "@types/pg": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11"
}
